{
  "info": {
    "title": "api-boilerplate",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "ok"
          },
          "service": {
            "type": "string",
            "example": "api-boilerplate"
          },
          "status": {
            "type": "string",
            "enum": [
              "ok"
            ],
            "example": "ok"
          }
        },
        "required": [
          "message",
          "service",
          "status"
        ]
      },
      "ErrorEnvelope": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "example": "invalid_request"
              },
              "details": {},
              "message": {
                "type": "string",
                "example": "Request validation failed"
              },
              "requestId": {
                "type": "string",
                "example": "f3a3ce38-66f0-4425-82b6-fce8db85b95b"
              }
            },
            "required": [
              "code",
              "message",
              "requestId"
            ]
          }
        },
        "required": [
          "error"
        ]
      },
      "ExampleEchoResponse": {
        "type": "object",
        "properties": {
          "greeting": {
            "type": "string",
            "example": "Hello, Pat!"
          }
        },
        "required": [
          "greeting"
        ]
      },
      "ExampleEchoBody": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "example": "Pat"
          }
        },
        "required": [
          "name"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/healthz": {
      "get": {
        "summary": "Liveness check",
        "tags": [
          "system"
        ],
        "responses": {
          "200": {
            "description": "Liveness probe",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/readyz": {
      "get": {
        "summary": "Readiness check",
        "tags": [
          "system"
        ],
        "responses": {
          "200": {
            "description": "Readiness probe",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    },
    "/examples/echo": {
      "post": {
        "summary": "Example typed route",
        "tags": [
          "examples"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExampleEchoBody"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Echoes a greeting",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExampleEchoResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          }
        }
      }
    }
  },
  "webhooks": {}
}
