{
  "extends": ["config:recommended"],
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "description": "Group workspace dependencies together",
      "groupName": "workspace dependencies",
      "matchManagers": ["npm"]
    },
    {
      "description": "Require manual review for majors",
      "automerge": false,
      "matchUpdateTypes": ["major"]
    },
    {
      "description": "Automerge safe dependency updates",
      "automerge": true,
      "matchUpdateTypes": ["minor", "patch", "digest", "pin"]
    }
  ]
}
